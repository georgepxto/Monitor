# URL do frontend em produção (ex: https://monitor.vercel.app)
CLIENT_URL=

# Chave secreta para proteger endpoints administrativos (/api/refresh e /api/test-notification)
# Gere uma chave forte: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_KEY=minha-chave-secreta-aqui
